{
	"name": "client",
	"version": "0.0.1",
	"type": "module",
	"description": "Open-source automation engine for MSPs.",
	"author": "Jack Musick <jack@gocovi.com>",
	"private": true,
	"engines": {
		"node": ">=20.0.0"
